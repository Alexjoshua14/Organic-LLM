# Homepage composer: local Ollama for route preview + plan intent (optional; requires Upstash rate limit)
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# Optional: different model for plan-mode JSON (defaults to OLLAMA_MODEL)
# OLLAMA_PLAN_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_API_KEY=

# Memory / Qdrant (Aetherion) — used by /status and memory search
# MEMORY_API_HOST=localhost
# MEMORY_API_PORT=6333
# MEMORY_API_SECRET=

# Supabase (service role for server checks on /status)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate limits, tab title cache) — /status pings when set
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Organic LLM — local environment template
# Copy to `.env.local` (gitignored). Placeholders only — never commit real secrets.
# See README "Running locally" and SECURITY.md for what not to commit.
#
# Legend:
#   [REQUIRED — signed-in]  Needed for /chat, /rabbitholes, /sandbox, and protected /api/*
#   [OPTIONAL]              Feature works without it, or degrades gracefully
#   [DEPLOY / CRON]         Production / scheduled jobs (not local dev)
#   [E2E / TEST]            Playwright or CI test harness only
#
# Demo routes (/showcase, /blog, /good-news?preview=1) need no .env.local — `bun dev` only.


# =============================================================================
# Clerk — authentication [REQUIRED — signed-in]
# Create an application at https://dashboard.clerk.com
# =============================================================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...


# =============================================================================
# Supabase — profiles, chats, rabbit holes [REQUIRED — signed-in]
# Schema snippets: docs/migrations/
# Regenerate types: bun run supabase:types (after `supabase link`)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# =============================================================================
# Chat encryption at rest [REQUIRED — signed-in]
# ORGANIC_LLM_ROOT_SECRET encrypts message bodies in Supabase.
# Generate a long random string (32+ bytes); do not rotate casually in dev.
# =============================================================================

ORGANIC_LLM_ROOT_SECRET=
# ORGANIC_LLM_ACTIVE_KEY_ID=k1
# ORGANIC_LLM_KEY_REGISTRY_JSON={"k0":"previous-root-secret-for-migration"}


# =============================================================================
# AI / Vercel AI Gateway [REQUIRED — signed-in chat LLM]
# Main chat (/api/chat, /api/ai/aion, profile knowledge, Good News pipeline) routes
# models through the gateway (e.g. openai/gpt-5.4-mini, anthropic/claude-sonnet-4.6).
# Get a key: https://vercel.com/docs/ai-gateway
# On Vercel deploy, VERCEL_OIDC_TOKEN is injected automatically as an alternative.
# =============================================================================

AI_GATEWAY_API_KEY=
# VERCEL_OIDC_TOKEN=   # auto on Vercel; optional local override


# =============================================================================
# OpenAI (direct provider) [OPTIONAL]
# Not used for main gateway chat. Needed for Mem0 fact-extraction (config/mem0-config.ts)
# and scripts/migrate-memories-v2.ts. Some legacy routes (spark, prometheus, remy) call
# openai() directly and need OPENAI_API_KEY if you use those endpoints.
# =============================================================================

# OPENAI_API_KEY=sk-...


# =============================================================================
# Upstash Redis [REQUIRED — signed-in]
# Rate limits (LLM messages, rabbit-hole nodes, homepage Ollama), tab-title cache.
# Chat POST returns 500 if Upstash is misconfigured. Free tier is enough for dev.
# =============================================================================

UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=


# =============================================================================
# Memory — Qdrant + Mem0 (Aetherion) [OPTIONAL]
# Without these, memory search/ingest and /status Qdrant checks fail or no-op.
# Local Qdrant: docker run -p 6333:6333 qdrant/qdrant
# Embeddings use local Ollama (see OLLAMA_* below) via config/mem0-config.ts.
# =============================================================================

# MEMORY_API_HOST=localhost
# MEMORY_API_PORT=6333
# MEMORY_API_SECRET=

# Memory payload encryption at rest in Qdrant [OPTIONAL]
# MEMORY_ENCRYPTION_CURRENT_KEY=k1
# MEMORY_ENCRYPTION_KEY_K1=   # base64, >= 32 decoded bytes
# MEMORY_ENCRYPTION_KEY_K2=   # optional second key for rotation


# =============================================================================
# Exa — web search tool [OPTIONAL]
# Chat web-search tool and rabbit-hole research return errors without EXA_API_KEY.
# =============================================================================

# EXA_API_KEY=


# =============================================================================
# ElevenLabs — text-to-speech [OPTIONAL]
# /api/ai/tts-v2 and speak UI need ELEVENLABS_API_KEY.
# =============================================================================

# ELEVENLABS_API_KEY=


# =============================================================================
# Ollama — local models [OPTIONAL]
# Homepage route preview + plan intent (/api/homepage/*); memory embeddings (nomic-embed-text).
# Requires Upstash for homepage rate limits. Defaults assume Ollama on localhost:11434.
# =============================================================================

# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_PLAN_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_API_KEY=   # only if your Ollama endpoint requires auth


# =============================================================================
# Clerk webhooks — profile sync on user.created [OPTIONAL — local]
# Run `bun run dev:full` to tunnel webhooks to /api/webhooks/clerk (needs ngrok).
# In Clerk Dashboard → Webhooks, point endpoint at your tunnel URL + set signing secret.
# Without webhooks, sign-in works but Supabase profile row may be missing until manual fix.
# =============================================================================

# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...


# =============================================================================
# Good News cron [DEPLOY / CRON]
# Vercel cron hits /api/good-news/cron (see vercel.json). Endpoint is closed without secret.
# Preview digest locally: /good-news?preview=1 (no CRON_SECRET needed).
# =============================================================================

# CRON_SECRET=


# =============================================================================
# Playwright E2E [E2E / TEST]
# bun run test:e2e — signed-in flows need a real Clerk test user.
# =============================================================================

# E2E_CLERK_EMAIL=
# E2E_CLERK_PASSWORD=
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# AION_TEST_MODE=1   # stubs /api/ai/aion stream in e2e (default in playwright.config.ts)

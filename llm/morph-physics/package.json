{
  "name": "@organic-llm/morph-physics",
  "version": "0.1.0",
  "description": "Spring-driven DOM layout morphing (Vector4 x,y,w,h) with optional React hook and Three.js mesh sync. Ported from Project Nebulae morph-lab.",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./webgl": {
      "types": "./dist/webgl.d.ts",
      "import": "./dist/webgl.js"
    },
    "./layout-relaxation": {
      "types": "./dist/layout-relaxation.d.ts",
      "import": "./dist/layout-relaxation.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsup"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^3.23.0 || ^4.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "tsup": "^8.5.1",
    "typescript": "~5.6.3",
    "vitest": "^4.1.8",
    "zod": "^3.24.0"
  }
}
